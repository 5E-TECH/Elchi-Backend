# ================= Runtime =================
NODE_ENV=development
PORT=3004

# ================= Service Ports =================
IDENTITY_PORT=3001
ORDER_PORT=3002
CATALOG_PORT=3003
LOGISTICS_PORT=3004
FINANCE_PORT=3005
NOTIFICATION_PORT=3006
INTEGRATION_PORT=3007
ANALYTICS_PORT=3008
BRANCH_PORT=3009
INVESTOR_PORT=3010
FILE_PORT=3011
C2C_PORT=3012
SEARCH_PORT=3013

# ================= Auth / JWT =================
ACCESS_TOKEN_KEY=change_me_access
ACCESS_TOKEN_TIME=15m
REFRESH_TOKEN_KEY=change_me_refresh
REFRESH_TOKEN_TIME=7d

# ================= RabbitMQ =================
RABBITMQ_URI=amqp://guest:guest@rabbitmq:5672
RABBITMQ_IDENTITY_QUEUE=identity_queue
RABBITMQ_ORDER_QUEUE=order_queue
RABBITMQ_CATALOG_QUEUE=catalog_queue
RABBITMQ_LOGISTICS_QUEUE=logistics_queue
RABBITMQ_FINANCE_QUEUE=finance_queue
RABBITMQ_NOTIFICATION_QUEUE=notification_queue
RABBITMQ_INTEGRATION_QUEUE=integration_queue
RABBITMQ_ANALYTICS_QUEUE=analytics_queue
RABBITMQ_BRANCH_QUEUE=branch_queue
RABBITMQ_INVESTOR_QUEUE=investor_queue
RABBITMQ_FILE_QUEUE=file_queue
RABBITMQ_C2C_QUEUE=c2c_queue
RABBITMQ_SEARCH_QUEUE=search_queue

# ================= PostgreSQL =================
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=elchipochta_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URI=postgres://myuser:mypassword@postgres:5432/elchipochta_db

# ================= Schema per service =================
# DB_SCHEMA=identity_schema
# DB_SCHEMA=order_schema
# DB_SCHEMA=catalog_schema
# DB_SCHEMA=logistics_schema
# DB_SCHEMA=finance_schema
# DB_SCHEMA=notification_schema
# DB_SCHEMA=integration_schema
# DB_SCHEMA=branch_schema
# DB_SCHEMA=investor_schema
# DB_SCHEMA=c2c_schema
# DB_SCHEMA=search_schema

# ================= Superadmin Seed =================
SUPERADMIN_NAME=Super Admin
SUPERADMIN_PHONE_NUMBER=+998900000000
SUPERADMIN_PASSWORD=superadmin123

# ================= MinIO / File Service =================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=elchi-files
FILE_SIGNED_URL_EXPIRES=3600
FILE_MAX_SIZE_MB=10

# ================= Telegram =================
TELEGRAM_BOT_TOKEN=replace_me

# ================= Integration Service =================
# AES key for encrypting external integration credentials (Yandex, SMS, etc.) at rest.
# MUST be >=32 random characters. Generate with: openssl rand -hex 32
# Rotating this invalidates existing encrypted credentials — plan a re-encrypt migration first.
INTEGRATION_CREDENTIAL_SECRET=replace_with_openssl_rand_hex_32

# ================= CORS =================
# Comma-separated list of allowed browser origins. localhost is always allowed.
# api.elchipochta.uz is required so the hosted Swagger UI can call the API.
CORS_ORIGINS=https://admin.elchipochta.uz,https://api.elchipochta.uz

# ================= Swagger (API docs) =================
# Swagger UI (/api) is protected by HTTP Basic Auth.
# In production Swagger is served only when SWAGGER_PASSWORD is set.
SWAGGER_USER=admin
SWAGGER_PASSWORD=change_me_swagger

# ================= Cloudflare Tunnel =================
# Token from Cloudflare Zero Trust -> Networks -> Tunnels.
# Used by the `cloudflared` service in docker-compose.prod.yml.
TUNNEL_TOKEN=replace_with_cloudflare_tunnel_token
